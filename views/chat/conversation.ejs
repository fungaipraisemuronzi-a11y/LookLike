<!DOCTYPE html>
<html>
<head>

  <title>Chat</title>

  <link
    rel="stylesheet"
    href="/css/style.css"
  >

</head>

<body>

<div class="feed-container">

  <h1>Chat</h1>

  <div class="post-card">

    <div id="messages">

      <% if (
        conversation.messages &&
        conversation.messages.length > 0
      ) { %>

        <% conversation.messages.forEach(message => { %>

          <div
            style="margin-bottom:20px;"
          >

            <p>

              <strong>
                <%= message.sender.username %>
              </strong>

            </p>

            <% if (message.text) { %>

              <p>
                <%= message.text %>
              </p>

            <% } %>

            <% if (message.image) { %>

              <img
                src="<%= message.image %>"
                style="
                  width:100%;
                  max-width:300px;
                  border-radius:12px;
                  margin-top:10px;
                "
              >

            <% } %>

          </div>

        <% }) %>

      <% } %>

    </div>

    <form
      id="chatForm"
      enctype="multipart/form-data"
    >

      <input
        type="text"
        id="messageInput"
        name="text"
        placeholder="Write message..."
      >

      <input
        type="file"
        id="imageInput"
        name="image"
        accept="image/*"
      >

      <button type="submit">
        Send
      </button>

    </form>

  </div>

</div>

<script src="/socket.io/socket.io.js"></script>

<script>

const socket = io();

const conversationId =
  "<%= conversation.id %>";

socket.emit(
  "joinConversation",
  conversationId
);

const form =
  document.getElementById(
    "chatForm"
  );

const messages =
  document.getElementById(
    "messages"
  );

form.addEventListener(
  "submit",
  async (e) => {

    e.preventDefault();

    const formData =
      new FormData(form);

    const response =
      await fetch(
        `/chat/conversation/${conversationId}/message`,
        {
          method: "POST",
          body: formData,
        }
      );

    if (response.ok) {

      document.getElementById(
        "messageInput"
      ).value = "";

      document.getElementById(
        "imageInput"
      ).value = "";

    }

  }
);

socket.on(
  "newMessage",
  (data) => {

    const div =
      document.createElement("div");

    div.style.marginBottom =
      "20px";

    let html =
      `<p><strong>${data.username}</strong></p>`;

    if (data.text) {

      html +=
        `<p>${data.text}</p>`;

    }

    if (data.image) {

      html += `
        <img
          src="${data.image}"
          style="
            width:100%;
            max-width:300px;
            border-radius:12px;
            margin-top:10px;
          "
        >
      `;

    }

    div.innerHTML = html;

    messages.appendChild(div);

  }
);

</script>

</body>
</html>