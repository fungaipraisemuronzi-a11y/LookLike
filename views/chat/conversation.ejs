<!DOCTYPE html>
<html>
<head>

  <title>Chat</title>

  <link
    rel="stylesheet"
    href="/css/style.css"
  >

</head>

<body>

<div class="feed-container">

  <h1>Chat</h1>

  <div class="post-card">

    <div id="messages">

      <% if (
        conversation.messages &&
        conversation.messages.length > 0
      ) { %>

        <% conversation.messages.forEach(message => { %>

          <p>

            <strong>
              <%= message.sender.username %>
            </strong>

            :

            <%= message.text %>

          </p>

        <% }) %>

      <% } else { %>

        <p>
          No messages yet.
        </p>

      <% } %>

    </div>

    <form id="chatForm">

      <input
        type="text"
        id="messageInput"
        placeholder="Write message..."
        required
      >

      <button type="submit">
        Send
      </button>

    </form>

  </div>

</div>

<!-- SOCKET.IO -->

<script src="/socket.io/socket.io.js"></script>

<script>

/* =========================
   SOCKET CONNECTION
========================= */

const socket = io();

socket.on(
  "connect",
  () => {

    console.log(
      "Socket connected:",
      socket.id
    );

  }
);

/* =========================
   CONVERSATION ID
========================= */

const conversationId =
 "<%= conversation.id %>";

socket.emit(
  "joinConversation",
  conversationId
);

console.log(
  "Joined conversation:",
  conversationId
);

/* =========================
   ELEMENTS
========================= */

const form =
  document.getElementById(
    "chatForm"
  );

const input =
  document.getElementById(
    "messageInput"
  );

const messages =
  document.getElementById(
    "messages"
  );

/* =========================
   RECEIVE LIVE MESSAGE
========================= */

socket.on(
  "newMessage",
  (data) => {

    console.log(
      "Received:",
      data
    );

    const p =
      document.createElement("p");

    p.innerHTML =
      `<strong>${data.username}</strong>: ${data.text}`;

    messages.appendChild(p);

    window.scrollTo(
      0,
      document.body.scrollHeight
    );

  }
);

/* =========================
   SEND MESSAGE
========================= */

form.addEventListener(
  "submit",
  async (e) => {

    e.preventDefault();

    const text =
      input.value.trim();

    if (!text) return;

    // LIVE MESSAGE

    socket.emit(
      "sendMessage",
      {
        conversationId,

        text,

        username:
          "<%= currentUser.username %>",
      }
    );

    // SAVE TO DATABASE

    await fetch(
      `/chat/conversation/${conversationId}/message`,
      {
        method: "POST",

        headers: {
          "Content-Type":
            "application/json",
        },

        body: JSON.stringify({
          text,
        }),
      }
    );

    input.value = "";

  }
);

</script>

</body>
</html>